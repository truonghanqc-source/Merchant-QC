{
  "name": "ai-generate_test",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:allure:always": "ALLURE_AUTO_OPEN=always playwright test",
    "test:api": "playwright test --config playwright.api.config.js",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "allure:clean": "rm -rf allure-results allure-report",
    "allure:generate": "rm -rf allure-report && allure generate ./allure-results --output allure-report",
    "allure": "node ./scripts/open-allure.mjs",
    "allure:open": "node ./scripts/open-allure.mjs",
    "allure:report": "node ./scripts/open-allure.mjs",
    "allure:api:clean": "rm -rf allure-results-api allure-report-api",
    "allure:api:generate": "rm -rf allure-report-api && allure generate ./allure-results-api --output allure-report-api",
    "allure:api:open": "npx allure open allure-results-api",
    "allure:api:report": "npm run allure:api:open",
    "test:e2e:allure": "npm run allure:clean && npm test && npm run allure:report",
    "test:ci": "CI=true playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "allure": "^3.7.0",
    "allure-playwright": "^3.7.2",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5",
    "xlsx": "^0.18.5"
  }
}
